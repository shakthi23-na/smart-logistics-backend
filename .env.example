# Environment Configuration Example

# Frontend URL (for CORS configuration in CorsConfig.java)
FRONTEND_URL=https://smart-logistics-frontend-mocha.vercel.app

# Optional: Database Configuration (for future upgrade)
# DB_URL=jdbc:postgresql://localhost:5432/logistics
# DB_USERNAME=postgres
# DB_PASSWORD=yourpassword

# Application Port
SERVER_PORT=8080

# Active Profile (dev, prod)
SPRING_PROFILES_ACTIVE=prod

# Logging Level
LOGGING_LEVEL=INFO
