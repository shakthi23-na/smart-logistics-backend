# Environment Configuration Example

# Frontend URL(s) (for CORS configuration in CorsConfig.java)
# Vercel Frontend
FRONTEND_URL=https://smart-logistics-frontend-mocha.vercel.app
# Azure Static App
AZURE_FRONTEND_URL=https://gray-dune-0b862e200.4.azurestaticapps.net

# Optional: Database Configuration (for future upgrade)
# DB_URL=jdbc:postgresql://localhost:5432/logistics
# DB_USERNAME=postgres
# DB_PASSWORD=yourpassword

# Application Port
SERVER_PORT=8080

# Active Profile (dev, prod)
SPRING_PROFILES_ACTIVE=prod

# Logging Level
LOGGING_LEVEL=INFO
